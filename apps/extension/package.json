{
  "name": "@transflow/extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown && node scripts/package.mjs",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@transflow/core": "workspace:*",
    "@transflow/google-translator": "workspace:*",
    "@transflow/openai-translator": "workspace:*",
    "@transflow/translator": "workspace:*",
    "jquery": "^4.0.0",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.26.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/chrome": "^0.1.40",
    "@types/jquery": "^4.0.0",
    "@types/node": "^24.0.0",
    "archiver": "^7.0.1",
    "babel-preset-solid": "^1.9.12",
    "tsdown": "^0.21.9",
    "typescript": "^5.9.0"
  }
}

{
  "manifest_version": 3,
  "name": "TransFlow - 沉浸式翻译",
  "version": "1.0.0",
  "description": "沉浸式双语翻译扩展，支持机器翻译与大模型翻译，可实时翻译网页、PDF 以及视频字幕。",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "transflow@transflow.dev",
      "strict_min_version": "115.0"
    }
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "TransFlow"
  },
  "background": {
    "scripts": ["background/service_worker.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "alarms", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["content/*", "assets/*", "pdf-viewer/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}

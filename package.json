{
  "name": "transflow",
  "version": "1.0.0",
  "private": true,
  "description": "TransFlow — immersive bilingual translation for Chromium, Firefox, Safari, and Tampermonkey/Userscript (monorepo).",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run build && oxlint --type-aware && turbo run typecheck",
    "typecheck": "turbo run typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "27.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6",
    "typescript": "^5.9.0",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9"
}

{
  "name": "@transflow/openai-translator",
  "version": "1.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@transflow/core": "workspace:*",
    "@transflow/translator": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^5.9.0"
  }
}
